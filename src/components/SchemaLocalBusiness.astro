  name: 'Bright Digital',
  alternateName: 'Bright Digital Group Limited',
  description:
    'Performance marketing agency in Auckland NZ. SEO, AEO, Google Ads, paid social, content strategy, marketing automation and CRO.',
  url: 'https://brightdigital.co.nz',
  telephone: '+64-21-226-4226',
