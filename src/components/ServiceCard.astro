---
interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
}
const { icon, title, description, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class:list={['service-card', { 'service-card-link': href }]} href={href}>
  <div class="service-icon" aria-hidden="true" set:html={icon} />
  <h3 class="service-card-title">{title}</h3>
  <p class="service-card-desc">{description}</p>
  {href && <span class="service-card-arrow" aria-hidden="true">Read more &rarr;</span>}
</Tag>

<style>
  .service-card {
    background: var(--dark3);
    border: var(--border);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
    color: inherit;
  }
  .service-card:hover {
    border-color: var(--green);
  }
  .service-card-link {
    cursor: pointer;
    text-decoration: none;
  }
  .service-card-link:hover {
    transform: translateY(-2px);
  }
  .service-icon {
    color: var(--green);
    background: rgba(255, 229, 35, 0.1);
    border-radius: 12px;
    width: 3rem;
    height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .service-icon :global(svg) {
    width: 1.5rem;
    height: 1.5rem;
  }
  .service-card-title {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1.3;
  }
  .service-card-desc {
    color: var(--gray);
    line-height: 1.55;
    flex: 1;
  }
  .service-card-arrow {
    color: var(--green);
    font-weight: 600;
    font-size: 0.9rem;
    margin-top: auto;
  }
</style>
