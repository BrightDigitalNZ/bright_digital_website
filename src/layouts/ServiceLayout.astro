---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import SchemaBreadcrumb from '../components/SchemaBreadcrumb.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getCollection } from 'astro:content';
import type { Service } from '../data/services';

interface Props {
  service: Service;
}
const { service } = Astro.props;

const url = `https://brightdigital.co.nz/services/${service.slug}`;

const breadcrumbs = [
  { name: 'Home', url: 'https://brightdigital.co.nz/' },
  { name: 'Services', url: 'https://brightdigital.co.nz/services/' },
  { name: service.title, url },
];

// Pull blog posts that name this service in their relatedServices frontmatter.
// Newest first, max three so the section stays scannable.
const relatedPosts = (await getCollection('blog', ({ data }) =>
  !data.draft && (data.relatedServices ?? []).includes(service.slug),
))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': service.schemaType,
  name: service.title,
  description: service.subtitle,
  url,
  provider: {
    '@type': 'Organization',
    '@id': 'https://brightdigital.co.nz/#organization',
    name: 'Bright Digital',
  },
  areaServed: [
    { '@type': 'Country', name: 'New Zealand' },
    { '@type': 'Country', name: 'Australia' },
  ],
};
---

<BaseLayout
  title={service.meta.title}
  description={service.meta.description}
  jsonLd={serviceSchema}
>
  <Nav />

  <main id="main">
    <PageHero title={service.title} subtitle={service.subtitle} />
    <div class="service-breadcrumb-wrap">
      <div class="service-breadcrumb-inner">
        <Breadcrumb crumbs={breadcrumbs} />
      </div>
    </div>

    {service.intro.body && (
      <section class="section section-dark">
        <div class="section-inner">
          <div class="intro-header">
            {service.intro.heading && <h2 class="h2 intro-heading">{service.intro.heading}</h2>}
            <p class="intro-text">{service.intro.body}</p>
          </div>

          {service.features.length > 0 && (
            <div class="features-grid">
              {service.features.map((f) => (
                <ServiceCard icon={f.icon} title={f.title} description={f.desc} />
              ))}
            </div>
          )}
        </div>
      </section>
    )}

    {relatedPosts.length > 0 && (
      <section class="section section-darker">
        <div class="section-inner">
          <h2 class="related-heading">Related reading</h2>
          <div class="related-grid">
            {relatedPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="related-card">
                <span class="related-card-category">{post.data.category}</span>
                <h3 class="related-card-title">{post.data.title}</h3>
                <p class="related-card-desc">{post.data.description}</p>
                <span class="related-card-arrow" aria-hidden="true">Read article &rarr;</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="cta-section">
      <div class="cta-inner">
        <h2 class="h2 h2-center">{service.cta.heading}</h2>
        <p class="cta-sub">{service.cta.sub}</p>
        <a href="/contact" class="btn-green">{service.cta.label}</a>
      </div>
    </section>
  </main>

  <Footer />

  <SchemaBreadcrumb crumbs={breadcrumbs} />
</BaseLayout>

<style>
  .intro-header {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    align-items: start;
    margin-bottom: 4rem;
  }
  .intro-heading {
    max-width: 30ch;
  }
  .intro-text {
    color: var(--gray2);
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .cta-section {
    background: var(--dark);
    padding: 6rem var(--pad-x);
    text-align: center;
  }
  .cta-inner {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
  }
  .cta-sub {
    color: var(--gray2);
    font-size: 1.1rem;
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .intro-header {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .related-heading {
    color: var(--white);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 2rem;
    text-align: center;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .related-card {
    background: var(--dark3);
    border: var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
  }
  .related-card:hover {
    border-color: var(--green);
    transform: translateY(-2px);
  }
  .related-card-category {
    color: var(--green);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .related-card-title {
    color: var(--white);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.3;
  }
  .related-card-desc {
    color: var(--gray);
    font-size: 0.95rem;
    line-height: 1.5;
    flex: 1;
  }
  .related-card-arrow {
    color: var(--green);
    font-weight: 600;
    font-size: 0.85rem;
  }

  .service-breadcrumb-wrap {
    background: var(--dark);
    padding: 1.25rem var(--pad-x);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .service-breadcrumb-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }
</style>
